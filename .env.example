# Supabase 환경변수 (로컬·Vercel 공통)
# 값은 Supabase Dashboard → Project Settings → API에서 복사
# 로컬 개발: 이 파일을 .env.local로 복사 후 값 채우기
# Vercel 배포: Project Settings → Environment Variables에 동일 키로 등록

# --- 클라이언트 노출 가능 (NEXT_PUBLIC_ 접두사) ---
# Project URL (예: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (legacy: anon key). 클라이언트·서버 공통, RLS 적용됨
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- 서버 전용 (절대 클라이언트 노출 금지) ---
# Service role key. RLS 우회 가능 — Server Action·Route Handler에서만 사용
# Vercel 등록 시 "Sensitive" 또는 server-only 환경에만 노출
SUPABASE_SERVICE_ROLE_KEY=
